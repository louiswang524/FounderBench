# FounderBench provider configuration examples.
# Copy to .env for your shell if desired, but never commit real API keys.

# DeepSeek hosted baseline
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic hosted baseline
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini hosted baseline
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible local/open-source model endpoint
OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
OPENAI_COMPAT_MODEL=Qwen/Qwen2.5-7B-Instruct
OPENAI_COMPAT_API_KEY=

# Optional cost accounting assumptions
MODEL_INPUT_COST_PER_MILLION=0
MODEL_OUTPUT_COST_PER_MILLION=0
PROVIDER_TIMEOUT_S=60

# Private holdout evaluator secret. Evaluators should keep this private.
FounderBench_HOLDOUT_SECRET=

