# FounderBench provider configuration examples.
# Copy to .env for your shell if desired, but never commit real API keys.

# OpenAI/GPT hosted baseline
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek hosted baseline
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic hosted baseline
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini hosted baseline
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Moonshot/Kimi OpenAI-compatible hosted baseline
KIMI_API_KEY=
KIMI_MODEL=kimi-latest
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Alibaba/Qwen OpenAI-compatible hosted baseline
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional additional hosted/open-weight families
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1
GLM_API_KEY=
GLM_MODEL=glm-4-plus
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
XAI_API_KEY=
XAI_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1
LLAMA_BASE_URL=http://localhost:8000/v1
LLAMA_MODEL=meta-llama/Llama-3.1-70B-Instruct
LLAMA_API_KEY=

# OpenAI-compatible local/open-source model endpoint
OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
OPENAI_COMPAT_MODEL=Qwen/Qwen2.5-7B-Instruct
OPENAI_COMPAT_API_KEY=

# Optional cost accounting assumptions
MODEL_INPUT_COST_PER_MILLION=0
MODEL_OUTPUT_COST_PER_MILLION=0
PROVIDER_TIMEOUT_S=60

# Private holdout evaluator secret. Evaluators should keep this private.
FounderBench_HOLDOUT_SECRET=
